{
  "info": {
    "_postman_id": "hapm-demo-workflows",
    "name": "HAPM Demo Workflows",
    "description": "Evaluator-facing demo collection. No login/register.\n\n**Before demo:**\n1. Run **HAPM Setup (Private)** collection (with 1500ms delay in Runner)\n2. Run folder **00 - Initialize IDs** here\n3. Follow **docs/Demo_Plan.md** folders **01** through **09** (folder **10** optional extras)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 - Initialize IDs (run once after Setup)",
      "description": "Pulls IDs from seeded demo data into environment variables. Run after prepare-evaluator-demo.ps1 and Setup logins.",
      "item": [
        {
          "name": "Set Available Slot",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('OK', () => pm.response.to.have.status(200));",
                "const slots = pm.response.json();",
                "if (slots.length) {",
                "  pm.environment.set('slotStart', slots[0].startTime);",
                "  pm.test('slotStart set', () => pm.expect(slots[0].startTime).to.be.ok);",
                "} else {",
                "  pm.test('No slots - update bookDate in environment', () => false);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/doctors/{{doctorId}}/available-slots?date={{bookDate}}"
          }
        },
        {
          "name": "Find Pending Appointment",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (j.items && j.items.length) {",
                "  pm.environment.set('pendingAppointmentId', j.items[0].id);",
                "  pm.environment.set('appointmentId', j.items[0].id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/appointments?status=Pending&pageSize=1"
          }
        },
        {
          "name": "Find Completed Appointment",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (j.items && j.items.length) {",
                "  pm.environment.set('completedAppointmentId', j.items[0].id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/appointments?status=Completed&pageSize=1"
          }
        },
        {
          "name": "Find Pending Invoice",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (j.items && j.items.length) {",
                "  pm.environment.set('pendingInvoiceId', j.items[0].id);",
                "  pm.environment.set('invoiceId', j.items[0].id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/invoices?status=Pending&pageSize=1"
          }
        },
        {
          "name": "Find Lab Report",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (j.items && j.items.length) pm.environment.set('labReportId', j.items[0].id);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/lab-reports?pageSize=1"
          }
        },
        {
          "name": "Find Prescription Template",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (j.length) pm.environment.set('templateId', j[0].id);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{doctorToken}}" }],
            "url": "{{baseUrl}}/api/prescription-templates"
          }
        },
        {
          "name": "Find Occupied Slot (409 demo)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (j.items && j.items.length) {",
                "  pm.environment.set('occupiedSlotStart', j.items[0].startTime);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/appointments?doctorId=1&fromDate={{bookDate}}&toDate={{bookDate}}&pageSize=1"
          }
        }
      ]
    },
