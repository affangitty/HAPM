    {
      "name": "03 - Patient Management",
      "description": "Registration, profiles, search, medical record (~2 min). Demo script seeds patient@hapm.local + demo.patient01–15.",
      "item": [
        {
          "name": "List Patients (pagination + search)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/patients?page=1&pageSize=5&search=demo&sortBy=name"
          }
        },
        {
          "name": "Get Patient by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/patients/{{patientId}}"
          }
        },
        {
          "name": "My Profile (patient)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
            "url": "{{baseUrl}}/api/patients/me"
          }
        },
        {
          "name": "Register Walk-in Patient",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const email = pm.environment.get('walkinEmail');",
                  "if (!email || String(email).trim() === '') {",
                  "  pm.environment.set('walkinEmail', 'walkin.demo.' + Date.now() + '@hapm.local');",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Created', () => pm.response.to.have.status(201));",
                  "const p = pm.response.json();",
                  "const presetId = pm.environment.get('walkinPatientId');",
                  "if (!presetId || String(presetId).trim() === '') {",
                  "  pm.environment.set('walkinPatientId', p.id);",
                  "}",
                  "pm.test('MRN assigned', () => pm.expect(p.medicalRecordNumber).to.match(/^MRN-/));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{receptionToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{walkinEmail}}\",\n  \"password\": \"Patient@12345\",\n  \"fullName\": \"Walk-in Demo Patient\",\n  \"phoneNumber\": \"+919998887766\",\n  \"dateOfBirth\": \"1988-03-20\",\n  \"gender\": \"Female\",\n  \"bloodGroup\": \"B+\",\n  \"address\": \"99 Clinic Road, Pune\",\n  \"allergies\": \"Penicillin\"\n}"
            },
            "url": "{{baseUrl}}/api/patients"
          }
        },
        {
          "name": "Get Walk-in Patient",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/patients/{{walkinPatientId}}"
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{patientToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Rahul Verma\",\n  \"phoneNumber\": \"+910000000004\",\n  \"dateOfBirth\": \"1992-04-18\",\n  \"gender\": \"Male\",\n  \"bloodGroup\": \"O+\",\n  \"address\": \"42 Lake View Road, Pune\",\n  \"emergencyContactName\": \"Priya Verma\",\n  \"emergencyContactPhone\": \"+919876543210\"\n}"
            },
            "url": "{{baseUrl}}/api/patients/{{patientId}}"
          }
        },
        {
          "name": "Medical History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
            "url": "{{baseUrl}}/api/patients/{{patientId}}/medical-history"
          }
        }
      ]
