            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/audit-logs?page=1&pageSize=10"
          }
        },
        {
          "name": "Export Appointments CSV",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/exports/appointments"
          }
