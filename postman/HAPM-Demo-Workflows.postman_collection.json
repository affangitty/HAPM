    {
      "name": "04 - Appointment Lifecycle (LIVE)",
      "description": "Book → confirm → check-in → vitals → prescribe → complete (~5 min). Uses reception/doctor tokens.",
      "item": [
        {
          "name": "Book Appointment",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Created', () => pm.response.to.have.status(200));",
                "pm.environment.set('appointmentId', pm.response.json().id);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{receptionToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": {{doctorId}},\n  \"patientId\": {{patientId}},\n  \"appointmentDate\": \"{{bookDate}}\",\n  \"startTime\": \"{{slotStart}}\",\n  \"reason\": \"Evaluator live demo visit\"\n}"
            },
            "url": "{{baseUrl}}/api/appointments"
          }
        },
        {
          "name": "Confirm Appointment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{doctorToken}}" }],
            "url": "{{baseUrl}}/api/appointments/{{appointmentId}}/confirm"
          }
        },
        {
          "name": "Check In",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{receptionToken}}" }],
            "url": "{{baseUrl}}/api/appointments/{{appointmentId}}/check-in"
          }
        },
        {
          "name": "Record Vitals (with BMI)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{receptionToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentId\": {{appointmentId}},\n  \"pulseBpm\": 76,\n  \"systolicBpMmHg\": 118,\n  \"diastolicBpMmHg\": 78,\n  \"temperatureCelsius\": 36.7,\n  \"heightCm\": 175,\n  \"weightKg\": 70\n}"
            },
            "url": "{{baseUrl}}/api/vitals"
          }
        },
        {
          "name": "Issue Prescription",
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["pm.environment.set('prescriptionId', pm.response.json().id);"],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{doctorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentId\": {{appointmentId}},\n  \"diagnosis\": \"Hypertension - controlled\",\n  \"followUpDate\": \"{{tomorrowDate}}\",\n  \"items\": [\n    {\n      \"medicineName\": \"Amlodipine\",\n      \"dosage\": \"5mg\",\n      \"frequency\": \"Once daily\",\n      \"durationDays\": 30\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/prescriptions"
          }
        },
        {
          "name": "Complete Appointment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{doctorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"Visit completed successfully - demo\"\n}" },
            "url": "{{baseUrl}}/api/appointments/{{appointmentId}}/complete"
          }
        },
        {
          "name": "Get Appointment Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/appointments/{{appointmentId}}"
          }
        }
      ]
    },
