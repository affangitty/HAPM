    {
      "name": "09 - Error Handling",
      "description": "ProblemDetails JSON for 404, 409, 400 (~2 min)",
      "item": [
        {
          "name": "404 Not Found",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/appointments/999999"
          }
        },
        {
          "name": "409 Double Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": 1,\n  \"patientId\": 1,\n  \"appointmentDate\": \"{{bookDate}}\",\n  \"startTime\": \"{{occupiedSlotStart}}\",\n  \"reason\": \"Duplicate slot demo\"\n}"
            },
            "url": "{{baseUrl}}/api/appointments"
          }
        },
        {
          "name": "400 Invalid Blood Pressure",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{receptionToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentId\": {{completedAppointmentId}},\n  \"systolicBpMmHg\": 80,\n  \"diastolicBpMmHg\": 120\n}"
            },
            "url": "{{baseUrl}}/api/vitals"
          }
        },
        {
          "name": "403 Patient Cannot Confirm",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
            "url": "{{baseUrl}}/api/appointments/{{pendingAppointmentId}}/confirm"
          }
        }
      ]
    },
    {
