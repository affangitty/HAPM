    {
      "name": "07 - Patient Experience",
      "description": "Notifications, reviews, waitlist (~2 min)",
      "item": [
        {
          "name": "Patient Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
            "url": "{{baseUrl}}/api/notifications?page=1&pageSize=10"
          }
        },
        {
          "name": "Unread Count",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
            "url": "{{baseUrl}}/api/notifications/unread-count"
          }
        },
        {
          "name": "Mark All Read",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
            "url": "{{baseUrl}}/api/notifications/read-all"
          }
        },
        {
          "name": "List Reviews",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/reviews?doctorId={{doctorId}}&pageSize=5"
          }
        },
        {
          "name": "Submit Review (run after folder 04)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{patientToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentId\": {{appointmentId}},\n  \"rating\": 5,\n  \"comment\": \"Excellent care during demo visit\"\n}"
            },
            "url": "{{baseUrl}}/api/reviews"
          }
        },
        {
          "name": "Join Waitlist",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) pm.environment.set('waitlistId', pm.response.json().id);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{patientToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": {{doctorId}},\n  \"preferredDate\": \"{{tomorrowDate}}\",\n  \"notes\": \"Demo waitlist entry\"\n}"
            },
            "url": "{{baseUrl}}/api/waitlist"
          }
        },
        {
          "name": "Waitlist Entries",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/waitlist?page=1&pageSize=10"
          }
        }
      ]
    },
